{
  "name": "opencode-plugin-han",
  "version": "0.2.0",
  "description": "Han bridge for OpenCode - enables Han's validation hooks and plugin ecosystem in OpenCode sessions",
  "main": "src/index.ts",
  "type": "module",
  "oc-plugin": ["server", "tui"],
  "exports": {
    ".": "./src/index.ts",
    "./tui": "./dist/tui/index.js"
  },
  "files": [
    "src/",
    "dist/tui/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.tui.json"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "han",
    "claude-code",
    "hooks",
    "validation",
    "linting",
    "bridge"
  ],
  "author": {
    "name": "The Bushido Collective",
    "url": "https://thebushido.co"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/thebushidocollective/han",
    "directory": "plugins/bridges/opencode"
  },
  "homepage": "https://github.com/thebushidocollective/han/tree/main/plugins/bridges/opencode",
  "engines": {
    "bun": ">=1.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.0 <2"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.18.0",
    "@opentui/core": "0.1.97",
    "@opentui/solid": "0.1.97",
    "@types/node": "^24.0.0",
    "solid-js": "1.9.11",
    "typescript": "^5.8.0"
  }
}
