{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist/tui",
    "rootDir": "src/tui",
    "declaration": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/solid",
    "types": ["node"]
  },
  "include": ["src/tui/**/*.ts", "src/tui/**/*.tsx"]
}
